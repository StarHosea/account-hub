# ============================================
# 账号管理平台 环境变量配置示例
# ============================================

# 认证密钥（必填）
ACCOUNT_HUB_AUTH_KEY=your_secret_key_here

# 基础 URL（可选，用于生成图片 URL）
# ACCOUNT_HUB_BASE_URL=https://your-domain.com

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认: json
# 说明：平台「基础设置」等配置随该后端一起持久化——
#   json     → data/config.json（state key: config）
#   sqlite   → 数据库 settings 表（与账号同库）
#   postgres → 数据库 settings 表（与账号同库）
#   git      → 仓库 config.json
# 已废弃 data/settings.json，首次启动会自动迁移。根目录 config.json 仅作为种子与 auth-key 兜底。
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/account_hub

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（不指定时自动使用 data/accounts.db）
# DATABASE_URL=sqlite:///app/data/accounts.db

# 激活审计库（始终使用数据库，不写入 JSON；未设置时默认 data/activation_audit.db）
# 可与主库共用：ACTIVATION_AUDIT_DATABASE_URL 留空且已配置 DATABASE_URL 则写入同库 activation_audit 表
# ACTIVATION_AUDIT_DATABASE_URL=sqlite:///app/data/activation_audit.db

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git 访问令牌（必填）
# GitHub: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认: accounts.json）
# GIT_FILE_PATH=accounts.json

# ============================================
# Plus CDK 兑换/激活（可选，优先于「设置」页填写的值）
# ============================================

# CDK 兑换服务地址与密钥（API Key 仅存后端，不回传前端）
# CDK_API_BASE_URL=https://cdk.example.com
# CDK_API_KEY=your_cdk_api_key_here

# ============================================
# CloakBrowser 浏览器注册引擎（可选）
# ============================================

# CloakBrowser Pro 授权（可选；不填走免费版 stealth Chromium）
# CLOAKBROWSER_LICENSE_KEY=your_cloakbrowser_pro_license

# CloakBrowser 启动失败时是否回退到 playwright-core chromium（默认 true；无 stealth 指纹，仅用于跑通链路）
# CLOAK_FALLBACK_CHROMIUM=true

# 诊断截图目录（可选；设置后注册流程失败/关键步骤会截图落盘，便于排查。默认关闭）
# REG_DIAG_DIR=/app/data/diag

